<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/nav_item_ripple">

    <!-- Mask ensures ripple respects rounded corners -->
    <item android:id="@android:id/mask">
        <inset
            android:insetLeft="12dp"
            android:insetRight="12dp"
            android:insetTop="4dp"
            android:insetBottom="4dp">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="14dp" />
            </shape>
        </inset>
    </item>

    <!-- Selected = soft rounded "pill" background -->
    <item>
        <selector>
            <!-- Press feedback: show a pill immediately (fixes "hotspot circle glitch") -->
            <item android:state_pressed="true">
                <inset
                    android:insetLeft="12dp"
                    android:insetRight="12dp"
                    android:insetTop="4dp"
                    android:insetBottom="4dp">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/nav_item_pressed_bg" />
                        <corners android:radius="14dp" />
                    </shape>
                </inset>
            </item>
            <item android:state_checked="true">
                <inset
                    android:insetLeft="12dp"
                    android:insetRight="12dp"
                    android:insetTop="4dp"
                    android:insetBottom="4dp">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/nav_item_selected_bg" />
                        <corners android:radius="14dp" />
                    </shape>
                </inset>
            </item>
            <item>
                <inset
                    android:insetLeft="12dp"
                    android:insetRight="12dp"
                    android:insetTop="4dp"
                    android:insetBottom="4dp">
                    <shape android:shape="rectangle">
                        <solid android:color="@android:color/transparent" />
                        <corners android:radius="14dp" />
                    </shape>
                </inset>
            </item>
        </selector>
    </item>
</ripple>
