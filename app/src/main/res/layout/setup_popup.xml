<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose your Experience:"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/PerformanceModeBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚀 Performance Mode\n(800x600, No Shadows, Max FPS)"
        android:textAlignment="viewStart"
        android:padding="16dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/GraphicsModeBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💎 Graphics Mode\n(Widescreen, High Res, Better Textures)"
        android:textAlignment="viewStart"
        android:padding="16dp" />

</LinearLayout>
